# ===================== 生产环境配置模板 =====================
# 复制此文件为 .env 并填入真实值

# --- 运行环境 ---
ENVIRONMENT=production
TESTING=false

# --- 数据库 (PostgreSQL + pgvector) ---
POSTGRES_USER=life_memory
POSTGRES_PASSWORD=replace-with-strong-password
POSTGRES_DB=life_memory
POSTGRES_URL=postgresql://life_memory:replace-with-strong-password@localhost:5432/life_memory

# --- Redis ---
# 使用 URL-safe 的随机值，例如：python -c "import secrets; print(secrets.token_urlsafe(32))"
REDIS_PASSWORD=replace-with-redis-password
REDIS_URL=redis://:replace-with-redis-password@localhost:6379/0

# --- JWT 认证 ---
SECRET_KEY=replace-with-long-random-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
SYSTEM_API_TOKEN=replace-with-32-character-system-token

# --- CORS（逗号分隔，生产环境改为实际域名）---
CORS_ORIGINS=https://your-domain.com

# --- LLM API ---
DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_API_URL=https://api.deepseek.com/v1

# --- Obsidian 同步 ---
OBSIDIAN_VAULT_PATH=./obsidian-vault

# --- 启动控制 ---
ENABLE_SCHEDULER=true
AGENT_RUNTIME_ENABLED=true
CONVERSATIONAL_AGENT_ENABLED=true
WORKING_AGENT_SHADOW_ENABLED=false
WORKING_AGENT_ACTIVE_ENABLED=true
# Working-Agent call budgets (reset at local midnight). These limit cost only;
# they do not weaken evidence, sensitivity, or provenance rules.
WORKING_AGENT_DAILY_MODEL_CALL_LIMIT=96
WORKING_AGENT_DAILY_PRIORITY_RESERVE=32
WORKING_AGENT_DAILY_MAINTENANCE_CALL_LIMIT=8
WORKING_AGENT_SCAN_BATCH_SIZE=20
WORKING_AGENT_BUDGET_TIMEZONE=Asia/Shanghai
# --- V3 Graphiti projection (start disabled; run Shadow replay first) ---
# Neo4j is internal-only. Do not put production passwords in source control.
GRAPHITI_ENABLED=false
GRAPHITI_SHADOW_MODE=true
GRAPHITI_NEO4J_URI=bolt://neo4j:7687
GRAPHITI_NEO4J_USER=neo4j
GRAPHITI_NEO4J_PASSWORD=
GRAPHITI_NEO4J_DATABASE=neo4j
GRAPHITI_LLM_API_KEY=
GRAPHITI_LLM_BASE_URL=https://api.deepseek.com/v1
GRAPHITI_LLM_MODEL=deepseek-chat
# Must be compatible with the configured Graphiti model provider before enabling.
GRAPHITI_EMBEDDING_MODEL=
GRAPHITI_PROJECTION_CONCURRENCY=1
GRAPHITI_BACKFILL_BATCH_SIZE_MAX=200
GRAPHITI_REQUIRE_SOLO_MODE=true
# Multi-user deployments must list the immutable IDs allowed to start/retry
# graph replay. Leave empty in solo mode; it fails closed elsewhere.
GRAPHITI_ADMIN_USER_IDS=
BOOTSTRAP_DEFAULTS=true
AUTO_PATCH_SCHEMA=false
CREATE_SCHEMA_ON_STARTUP=false
SOLO_MODE=true
# Public, anonymous MCP bootstrap is a single-owner convenience only. Keep
# disabled until the endpoint and its Nginx rate limit have been verified.
PUBLIC_MCP_BOOTSTRAP_ENABLED=false
ALLOW_SOLO_PRODUCTION=false
ALLOW_DEV_AUTH_FALLBACK=false

# --- 企业微信机器人长连接（可选，但推荐作为主入口）---
WECOM_BOT_ID=
WECOM_BOT_SECRET=
WECOM_DEFAULT_AGENT_ID=

# --- 全媒体笔记入口 ---
MEDIA_STORAGE_DIR=./data/media-artifacts
AGENT_WORKSPACE_DIR=./data/agent-workspaces
MEDIA_MAX_FILE_SIZE_BYTES=26214400
MEDIA_ALLOWED_MIME_TYPES=image/jpeg,image/png,image/webp,text/plain,text/markdown,text/html,text/csv,application/pdf,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet,application/vnd.ms-excel,application/vnd.openxmlformats-officedocument.wordprocessingml.document,application/vnd.openxmlformats-officedocument.presentationml.presentation,audio/mpeg,audio/wav,video/mp4

# 重型媒体增强默认关闭；安装 requirements-media-optional.txt 和系统依赖后再开启。
MEDIA_ENABLE_MARKITDOWN=false
MEDIA_ENABLE_RAPIDOCR=false
MEDIA_ENABLE_WHISPER=false
MEDIA_ENABLE_FFMPEG=false
MEDIA_ENABLE_YTDLP=false
MEDIA_MAX_TRANSCRIBE_SECONDS=600
MEDIA_EXTRACTION_TIMEOUT_SECONDS=120
MEDIA_EXTRACTION_CONCURRENCY=1

# --- Nginx 端口 ---
HTTP_PORT=80
HTTPS_PORT=443

# --- API 进程数 ---
# 企微长连接由 API 进程维护；单机私有模式建议保持 1，避免多进程重复订阅。
WEB_CONCURRENCY=1

# --- 新架构特性（第三轮迭代默认开启）---
# LLM/embedding 结果缓存（OrderedDict LRU）。单用户本地系统建议开启以节省 API 调用。
ENABLE_LLM_CACHE=true
LLM_CACHE_MAX_SIZE=1000

# Reranker 精排（LLM-based，参考 mem0）。增加一次 LLM 调用延迟，但显著提升检索质量。
# 单用户本地系统可接受；高并发生产环境可关闭。
ENABLE_RERANKER=true
RERANKER_TOP_K=5
RERANKER_MAX_CANDIDATES=20

# 混合检索模式：'fallback'（串行降级）| 'parallel'（三信号并行融合，参考 Graphiti）
# parallel 模式：vector(0.6) + BM25(0.3) + recency(0.1) 通过 asyncio.gather 并行计算
HYBRID_SEARCH_MODE=parallel
HYBRID_WEIGHT_VECTOR=0.6
HYBRID_WEIGHT_BM25=0.3
HYBRID_WEIGHT_RECENCY=0.1
